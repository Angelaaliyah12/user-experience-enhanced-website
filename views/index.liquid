{% render 'partials/header.liquid' %}

  <body>
    <header class="header">
      <picture>
        <source srcset="/assets/milledoni-icon.avif" type="image/avif">
        <source srcset="/assets/milledoni-icon.webp" type="image/webp">
         <img width="200" height="50" class="icon" src="/assets/milledoni-icon.png" alt="milledoni icon">
      </picture>

      <div class="header-right">
        <picture>
          <source srcset="/assets/filter.avif" type="image/avif">
          <source srcset="/assets/filter.webp" type="image/webp">
           <img width="50" height="50" class="filter" src="/assets/filter.png" alt="filter icoon">
        </picture>
        <a href="/lijst"  aria-label="ga naar je lijst">
          <picture>
            <source srcset="/assets/list.avif" type="image/avif">
            <source srcset="/assets/list.webp" type="image/webp">
            <img width="50" height="50" class="list" src="/assets/list.png" alt="icoon naar lijst ">
          </picture>
        </a>
        <picture>
          <source srcset="/assets/profile-icon.avif" type="image/avif">
          <source srcset="/assets/profile-icon.webp" type="image/webp">
        <img width="50" height="50" class="profile-icon" src="/assets/profile-icon.png" alt="profile icon">
        </picture>
      </div>
    </header>
    <main>
      <div class="layout">
        <div class="left-side">
          <picture>
            <source srcset="/assets/ai-search.avif" type="image/avif">
            <source srcset="/assets/ai-search.webp" type="image/webp">
            <img width="50" height="50" class="ai" src="/assets/ai-search.png" alt="zoekbalk">
          </picture>
        </div>

        <div class="right-side">
          <ul class="product-lijst">
                    {% for product in products %}
              <li class="product-kaart">
                <a href="/product/{{ product.id }}"  aria-label="Bekijk {{ product.name }}">
                 
      {% if product.image %}
                     <img width="150" height="200"class="product-img" src="{{ product.image }}" alt="Bekijk {{ product.name }}">
       {% else %}
        <picture>
          <source srcset="/assets/placeholder.avif" type="image/avif">
          <source srcset="/assets/placeholder.webp" type="image/webp">
          <img width="150" height="200" class="product-img" src="/assets/placeholder.png"  alt="Placeholder afbeelding">
        </picture>
      {% endif %}
                </a>
                <form method="POST" action="/opslaan">
                  <input type="hidden" name="productId" value="{{ product.id }}">
                  <button type="submit" class="opslaan-knop" aria-label="sla cadeau op">
                    Save
                  </button>
                </form>

                <h2>{{ product.name }}</h2>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </main>

    <footer>
      <ul class="categorie-paginas">
        <li><a href="/valentijnsdag" aria-label="ga naar valentijnsdag pagina">Valentijn cadeaus </a></li>
        <li><a href="/cultuur" aria-label="ga naar cultuur pagina">Culturele cadeaus</a></li>
      </ul>
    </footer>
  </body>
</html>
